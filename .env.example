# 推荐生产架构：ROAM -> Hermes Agent -> New API。
# 仅服务端使用，任何密钥都不要加 NEXT_PUBLIC_ 前缀。
AI_BACKEND=hermes
HERMES_BASE_URL=http://hermes:8642/v1
HERMES_API_KEY=
HERMES_MODEL=roam-agent
AI_REQUEST_TIMEOUT_MS=180000

# PostgreSQL 持久化。生产环境必须配置；程序会自动创建独立的 roam schema。
DATABASE_URL=postgres://用户名:密码@数据库地址:5432/数据库名
DATABASE_SSL=false
# DATABASE_POOL_MAX=10

# 测试阶段快捷登录。正式开放前将 ENABLE_TEST_LOGIN 设为 false。
ENABLE_TEST_LOGIN=true
TEST_USER_NAME=roam-test
TEST_USER_DISPLAY_NAME=ROAM 测试用户
TEST_USER_PASSWORD=请在生产环境设置随机强密码

# 不使用 Hermes 时，把 AI_BACKEND 改为 openai 并配置下面这些变量。
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# OpenAI 官方使用 https://api.openai.com/v1；New API 填你的中转地址并保留 /v1。
OPENAI_BASE_URL=https://api.openai.com/v1

# 以下三项可以留空让程序自动判断：官方 OpenAI 使用 Responses；其他 Base URL 使用 Chat Completions + JSON Object。
# OPENAI_API_MODE=responses
# OPENAI_STRUCTURED_OUTPUT=json_schema

# 只有上游支持 Responses API 的 web_search 工具时才开启；普通 New API 中转建议设为 false。
# OPENAI_ENABLE_WEB_SEARCH=true
