# 仅服务端使用，不要写成 NEXT_PUBLIC_OPENAI_API_KEY
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# OpenAI 官方使用 https://api.openai.com/v1；New API 填你的中转地址并保留 /v1。
OPENAI_BASE_URL=https://api.openai.com/v1

# New API 如果完整支持 Responses API，使用 responses；只支持传统兼容接口时改为 chat_completions。
OPENAI_API_MODE=responses

# 只有上游支持 Responses API 的 web_search 工具时才开启；普通 New API 中转建议设为 false。
OPENAI_ENABLE_WEB_SEARCH=true
